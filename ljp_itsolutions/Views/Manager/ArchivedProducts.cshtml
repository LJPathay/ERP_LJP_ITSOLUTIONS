@model IEnumerable<ljp_itsolutions.Models.Product>
@{
    ViewData["Title"] = "Archived Products";
    ViewData["Subtitle"] = "Manage previously removed menu items from the system.";
}

<div class="container-fluid py-4">
    <!-- Back Button & Page Header -->
    <div class="d-flex align-items-center gap-3 mb-4">
        <a asp-action="Products" class="btn btn-outline-secondary rounded-circle p-2 shadow-sm border-0 transition-hover" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
            <i class="fas fa-arrow-left"></i>
        </a>
    </div>

    <!-- Stats Mini -->
    <div class="card border-0 shadow-sm rounded-4 mb-4 bg-light overflow-hidden">
        <div class="card-body p-4">
            <div class="row align-items-center">
                <div class="col-auto">
                    <div class="icon-box-lg brand-amber rounded-3 shadow-none">
                        <i class="fas fa-archive"></i>
                    </div>
                </div>
                <div class="col">
                    <div class="x-small text-muted fw-bold mb-1">TOTAL ARCHIVED ITEMS</div>
                    <div class="h4 fw-bold text-dark mb-0">@Model.Count() Products</div>
                </div>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm rounded-4 text-center p-5">
            <div class="opacity-25 mb-3">
                <i class="fas fa-folder-open fa-4x text-muted"></i>
            </div>
            <h4 class="text-muted fw-bold">No Archived Products</h4>
            <p class="text-muted">When you archive a product, it will appear here for safe keeping.</p>
            <div class="mt-3">
                <a asp-action="Products" class="btn btn-primary rounded-pill px-4">Back to Menu</a>
            </div>
        </div>
    }
    else
    {
        <!-- Archived Products Table -->
        <div class="modern-table shadow-soft">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th class="ps-4">Product Information</th>
                            <th>Category</th>
                            <th>Last Known Price</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr class="product-row animate__animated animate__fadeIn">
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="me-3 position-relative opacity-75 grayscale-img">
                                            @if (!string.IsNullOrEmpty(item.ImageURL))
                                            {
                                                <img src="@item.ImageURL" alt="@item.ProductName" class="rounded-3 shadow-sm" style="width: 48px; height: 48px; object-fit: cover; border: 2px solid white;" />
                                            }
                                            else
                                            {
                                                <div class="bg-light rounded-3 d-flex align-items-center justify-content-center border" style="width: 48px; height: 48px;">
                                                    <i class="fas fa-image text-muted"></i>
                                                </div>
                                            }
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark opacity-75">@item.ProductName</div>
                                            <div class="text-muted text-xs">ID: #@item.ProductID</div>
                                        </div>
                                    </div>
                                </td>
                                <td><span class="status-badge dark">@item.Category?.CategoryName</span></td>
                                <td class="fw-bold text-dark">₱@item.Price.ToString("F2")</td>
                                <td class="text-end pe-4">
                                    <form asp-action="RestoreProduct" method="post" class="d-inline" onsubmit="return confirm('Restore this product? It will reappear in the POS menu.');">
                                        <input type="hidden" name="id" value="@item.ProductID" />
                                        <button type="submit" class="btn btn-primary btn-sm rounded-pill px-4 shadow-sm">
                                            <i class="fas fa-undo me-2"></i>Restore
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<style>
    .grayscale-img img {
        filter: grayscale(100%);
    }
    .status-badge.dark {
        background-color: #f1f3f5;
        color: #495057;
    }
    .brand-amber {
        background-color: #fff4e6;
        color: #f76707;
    }
    .icon-box-lg {
        width: 56px;
        height: 56px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
    }
    .transition-hover:hover {
        transform: translateY(-2px);
        background-color: #f8f9fa !important;
    }
</style>
